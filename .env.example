NODE_ENV=development
APP_PORT=4000
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true

MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DATABASE=uix_db
MONGO_USERNAME=uix_user
MONGO_PASSWORD=uix_password
MONGO_AUTH_SOURCE=admin
MONGO_URI=mongodb://uix_user:uix_password@mongodb:27017/uix_db?authSource=admin

MONGO_EXPRESS_PORT=8081
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=change_me

REDIS_PASSWORD=change_me_redis
REDIS_PORT=6379
REDIS_PORT_CONTAINER=6379

LLM_DEFAULT_PROVIDER=ollama
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-change-me
OPENAI_MODEL=gpt-4o-mini

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_OPENAI_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=tinyllama:latest

REQUEST_TIMEOUT_MS=60000
SSE_ENABLED=true
SSE_KEEPALIVE_MS=15000

CORS_ORIGIN=*

MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025